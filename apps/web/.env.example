NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# NextAuth v5 — generate a secret with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (optional — falls back to demo Credentials provider if unset).
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
